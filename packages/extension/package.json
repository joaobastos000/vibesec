{
  "name": "vibeguard-vscode",
  "displayName": "VibeGuard",
  "description": "Local security guard for AI-generated code before it reaches your workspace.",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "publisher": "vibeguard",
  "categories": ["Linters", "Security", "Other"],
  "keywords": ["security", "ai", "vibe coding", "secrets", "scanner"],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vibeguard.scanCurrentFile",
    "onCommand:vibeguard.scanProject",
    "onCommand:vibeguard.guardClipboardBeforePaste",
    "onCommand:vibeguard.showOutput"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeguard.scanCurrentFile",
        "title": "VibeGuard: Scan Current File"
      },
      {
        "command": "vibeguard.scanProject",
        "title": "VibeGuard: Scan Project"
      },
      {
        "command": "vibeguard.guardClipboardBeforePaste",
        "title": "VibeGuard: Guard Clipboard Before Paste"
      },
      {
        "command": "vibeguard.showOutput",
        "title": "VibeGuard: Show Output"
      }
    ],
    "configuration": {
      "title": "VibeGuard",
      "properties": {
        "vibeguard.language": {
          "type": "string",
          "default": "pt-BR",
          "enum": ["pt-BR", "en-US"]
        },
        "vibeguard.aiProvider": {
          "type": "string",
          "default": "local",
          "enum": ["local", "openai", "anthropic", "disabled"]
        },
        "vibeguard.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Scan supported files when they are saved."
        },
        "vibeguard.insertSafeClipboard": {
          "type": "boolean",
          "default": true,
          "description": "Insert clipboard content automatically when Guard Clipboard Before Paste finds no blocking issue."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup ./src/extension.ts --format cjs --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies --out dist/vibeguard-vscode.vsix",
    "test": "node --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.9.2",
    "@vibeguard/core": "0.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
