{
  "name": "vibin-guard",
  "displayName": "VibinGuard",
  "description": "Local security guard for AI-generated code before it reaches your workspace.",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "publisher": "vibinguard",
  "license": "MIT",
  "pricing": "Free",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaobastos000/vibesec.git",
    "directory": "packages/extension"
  },
  "homepage": "https://github.com/joaobastos000/vibesec#readme",
  "bugs": {
    "url": "https://github.com/joaobastos000/vibesec/issues"
  },
  "categories": [
    "Linters",
    "Security",
    "Other"
  ],
  "keywords": [
    "security",
    "ai",
    "vibe coding",
    "secrets",
    "scanner"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vibinguard.scanCurrentFile",
    "onCommand:vibinguard.scanProject",
    "onCommand:vibinguard.guardClipboardBeforePaste",
    "onCommand:vibinguard.showOutput"
  ],
  "main": "./dist/extension.cjs",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "vibinguard.scanCurrentFile",
        "title": "VibinGuard: Scan Current File"
      },
      {
        "command": "vibinguard.scanProject",
        "title": "VibinGuard: Scan Project"
      },
      {
        "command": "vibinguard.guardClipboardBeforePaste",
        "title": "VibinGuard: Guard Clipboard Before Paste"
      },
      {
        "command": "vibinguard.showOutput",
        "title": "VibinGuard: Show Output"
      }
    ],
    "configuration": {
      "title": "VibinGuard",
      "properties": {
        "vibinguard.language": {
          "type": "string",
          "default": "pt-BR",
          "enum": [
            "pt-BR",
            "en-US"
          ],
          "description": "Language used in generated security guidance."
        },
        "vibinguard.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Scan supported files when they are saved."
        },
        "vibinguard.insertSafeClipboard": {
          "type": "boolean",
          "default": true,
          "description": "Insert clipboard content automatically when Guard Clipboard Before Paste finds no blocking issue."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "build:test": "tsup --config tsup.test.config.mjs",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies --out dist/vibin-guard.vsix",
    "test": "npm run build && npm run build:test && node dist/test/run-test.cjs",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@vibinguard/core": "0.1.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
