{
  "name": "vibeguard-vscode",
  "displayName": "VibeGuard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "publisher": "vibeguard",
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onCommand:vibeguard.scanCurrentFile",
    "onCommand:vibeguard.scanProject"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeguard.scanCurrentFile",
        "title": "VibeGuard: Scan Current File"
      },
      {
        "command": "vibeguard.scanProject",
        "title": "VibeGuard: Scan Project"
      }
    ],
    "configuration": {
      "title": "VibeGuard",
      "properties": {
        "vibeguard.language": {
          "type": "string",
          "default": "pt-BR",
          "enum": ["pt-BR", "en-US"]
        },
        "vibeguard.aiProvider": {
          "type": "string",
          "default": "local",
          "enum": ["local", "openai", "anthropic", "disabled"]
        }
      }
    }
  },
  "scripts": {
    "build": "tsup ./src/extension.ts --format cjs --dts --clean",
    "clean": "rimraf dist",
    "dev": "tsup ./src/extension.ts --format cjs --watch",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibeguard/core": "0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
